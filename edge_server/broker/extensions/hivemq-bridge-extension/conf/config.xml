<?xml version="1.0" encoding="UTF-8"?>
<!--
  HiveMQ Enterprise Bridge Extension configuration — edge_server side.
  The edge_server passively receives data from the edge_gateway via the gateway's bridge.
  This config bridges the edge_server further upstream to a cloud broker (optional).

  Topic flow:
    edge_gateway → [gateway bridge] → edge_server → [this bridge] → cloud broker

  Replace CLOUD_BROKER_HOST with the hostname/IP of your cloud MQTT broker.
-->
<hivemq-bridge-extension xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                         xsi:noNamespaceSchemaLocation="config.xsd">
    <bridges>
        <bridge>
            <name>cloud-bridge</name>

            <remote-broker>
                <!-- Uncomment and fill in if the cloud broker requires authentication
                <authentication>
                    <mqtt-simple-authentication>
                        <username>edge-server-user</username>
                        <password>edge-server-password</password>
                    </mqtt-simple-authentication>
                </authentication>
                -->
                <connection>
                    <static>
                        <!-- Replace with the hostname/IP of your cloud MQTT broker -->
                        <host>CLOUD_BROKER_HOST</host>
                        <port>1883</port>
                    </static>
                </connection>
                <mqtt>
                    <client-identifier>edge-server-bridge</client-identifier>
                    <clean-start>true</clean-start>
                    <keep-alive>60</keep-alive>
                    <session-expiry>0</session-expiry>
                    <version>MQTT_5</version>
                </mqtt>
                <!-- Uncomment to enable TLS towards the cloud broker
                <tls>
                    <enabled>true</enabled>
                </tls>
                -->
            </remote-broker>

            <topics>
                <!-- Forward the full UNS namespace up to the cloud.
                     Topics already carry the UNS prefix applied by each gateway bridge. -->
                <topic>
                    <filter>uns/#</filter>
                    <mode>PUB</mode>
                </topic>

                <!-- Pull commands from the cloud and let them propagate down.
                     Each gateway's SUB filter scopes commands to its own subtree. -->
                <topic>
                    <filter>commands/#</filter>
                    <mode>SUB</mode>
                </topic>
            </topics>

        </bridge>
    </bridges>

</hivemq-bridge-extension>
