<?xml version="1.0" encoding="UTF-8"?>
<!-- Default bridge config. The deploy scripts copy this to config.xml on first
     run (config.xml is gitignored so its runtime broker address never causes
     pull conflicts). The gateway-agent rewrites the broker host below when the
     bridge is configured from the dashboard. -->
<hivemq-bridge-extension xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                         xsi:noNamespaceSchemaLocation="config.xsd">
    <bridges>
        <bridge>
            <name>edge-server-bridge</name>

            <remote-broker>
                <connection>
                    <static>
                        <host>EDGE_SERVER_IP</host>
                        <port>1883</port>
                    </static>
                </connection>
                <mqtt>
                    <clean-start>true</clean-start>
                    <keep-alive>60</keep-alive>
                    <session-expiry>0</session-expiry>
                    <version>5</version>
                </mqtt>
            </remote-broker>

            <topics>
                <topic>
                    <filter>#</filter>
                    <mode>PUB</mode>
                    <destination>uns/enterprise/site/area/line/{#}</destination>
                </topic>
                <topic>
                    <filter>commands/enterprise/site/area/line/#</filter>
                    <mode>SUB</mode>
                </topic>
            </topics>

        </bridge>
    </bridges>

</hivemq-bridge-extension>
