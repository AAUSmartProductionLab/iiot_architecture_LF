<?xml version="1.0" encoding="UTF-8" ?>
<!--
  HiveMQ MQTT Bridge Extension configuration — edge_gateway side.
  This broker (edge_gateway) initiates the connection to the edge_server broker.

  Replace EDGE_SERVER_IP with the IP address or hostname of the edge_server machine.
  Replace the UNS prefix segments (enterprise/site/area/line) to match your
  Unified Namespace hierarchy for this specific gateway.

  Topic flow (with UNS prefix applied on forward):
    devices/sensor1/temp  →  edge_gateway  →  [bridge]  →  edge_server: uns/enterprise/site/area/line/sensor1/temp
    commands/#            ←  edge_gateway  ←  [bridge]  ←  edge_server (no prefix strip needed — scoped by gateway client-id)

  The <destination> element remaps the topic when publishing to the remote broker.
  {#} is substituted with the wildcard-matched portion of the original topic,
  preserving the full device-level structure under the UNS prefix.
-->
<mqtt-bridge>

    <bridges>
        <bridge>
            <id>edge-server-bridge</id>

            <!-- edge_server broker -->
            <host>EDGE_SERVER_IP</host>
            <port>1883</port>
            <client-id>gateway-bridge</client-id>
            <clean-start>true</clean-start>
            <session-expiry-interval>0</session-expiry-interval>
            <mqtt-version>MQTT_5</mqtt-version>
            <keep-alive>60</keep-alive>
            <connection-timeout>10</connection-timeout>
            <reconnect-interval>5</reconnect-interval>

            <!-- Uncomment and fill in if the edge_server broker requires authentication
            <username>gateway-user</username>
            <password>gateway-password</password>
            -->

            <!-- Uncomment to enable TLS towards the edge_server broker
            <tls>
                <enabled>true</enabled>
            </tls>
            -->

            <!-- Push local device/sensor data up to the edge_server with UNS prefix.
                 devices/sensor1/temp  →  uns/enterprise/site/area/line/sensor1/temp
                 Adjust the prefix segments to match this gateway's position in the hierarchy. -->
            <local-subscriptions>
                <local-subscription>
                    <filters>
                        <mqtt-topic-filter>devices/#</mqtt-topic-filter>
                    </filters>
                    <destination>uns/enterprise/site/area/line/{#}</destination>
                    <max-qos>1</max-qos>
                </local-subscription>
            </local-subscriptions>

            <!-- Pull commands/config scoped to this gateway from the edge_server.
                 The gateway subscribes to its own subtree so commands from the
                 edge_server are automatically routed to the right gateway. -->
            <remote-subscriptions>
                <remote-subscription>
                    <filters>
                        <mqtt-topic-filter>commands/enterprise/site/area/line/#</mqtt-topic-filter>
                    </filters>
                    <max-qos>1</max-qos>
                </remote-subscription>
            </remote-subscriptions>

        </bridge>
    </bridges>

</mqtt-bridge>
