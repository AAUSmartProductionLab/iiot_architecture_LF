# Dev image: Vite dev server with hot-module reload.
# Source is bind-mounted at runtime; node_modules lives in an anonymous volume
# so the container's installed deps aren't shadowed by the host mount.
FROM node:20-alpine

WORKDIR /app

COPY package.json ./
RUN npm install

COPY . .

EXPOSE 5173

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
